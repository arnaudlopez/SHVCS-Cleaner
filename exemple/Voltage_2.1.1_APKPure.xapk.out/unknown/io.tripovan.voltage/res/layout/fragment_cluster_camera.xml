<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:gravity="center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent"
  xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
            <LinearLayout android:orientation="horizontal" android:padding="10.0dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                <Button android:id="@id/sync" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sync time" android:layout_weight="1.0" app:icon="@drawable/clock" style="?materialIconButtonOutlinedStyle" />
                <Button android:id="@id/restartCluster" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Restart Cluster" android:layout_weight="1.0" app:icon="@drawable/sync_24px" style="?materialIconButtonOutlinedStyle" />
            </LinearLayout>
            <LinearLayout android:orientation="horizontal" android:padding="10.0dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                <Button android:id="@id/tsmTest" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Traffic sign memory test" android:layout_weight="1.0" style="?materialIconButtonOutlinedStyle" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
