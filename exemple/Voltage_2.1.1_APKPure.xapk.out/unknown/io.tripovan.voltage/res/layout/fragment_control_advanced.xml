<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:gravity="center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent"
  xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
            <LinearLayout android:orientation="horizontal" android:padding="10.0dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                <Button android:id="@id/clearDtcs" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Clear DTCs" android:layout_weight="1.0" app:icon="@drawable/delete" style="?materialIconButtonOutlinedStyle" />
            </LinearLayout>
            <com.google.android.material.divider.MaterialDivider android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginVertical="10.0dp" />
            <LinearLayout android:orientation="horizontal" android:padding="10.0dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                <Button android:id="@id/batteryCoolantPumpOn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Batt. Coolant Pump ON" android:layout_weight="1.0" style="?materialIconButtonOutlinedStyle" />
                <Button android:id="@id/batteryCoolantPumpOff" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Batt. Coolant Pump OFF" android:layout_weight="1.0" style="?materialIconButtonOutlinedStyle" />
            </LinearLayout>
            <LinearLayout android:orientation="horizontal" android:padding="10.0dp" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content">
                <Button android:id="@id/batteryCoolantHeaterOn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Batt. Heater ON" android:layout_weight="1.0" style="?materialIconButtonOutlinedStyle" />
                <Button android:id="@id/batteryCoolantHeaterOff" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Batt. Heater OFF" android:layout_weight="1.0" style="?materialIconButtonOutlinedStyle" />
            </LinearLayout>
            <com.google.android.material.divider.MaterialDivider android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginVertical="10.0dp" />
            <LinearLayout android:orientation="horizontal" android:padding="10.0dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                <Button android:id="@id/resetLifetimeCharge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reset lifetime charge" android:layout_weight="1.0" style="?materialIconButtonOutlinedStyle" />
                <Button android:id="@id/reset_number_of_charges" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reset # of charges" android:layout_weight="1.0" style="?materialIconButtonOutlinedStyle" />
            </LinearLayout>
            <LinearLayout android:orientation="horizontal" android:padding="10.0dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                <Button android:id="@id/resetFuelLifetime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reset Fuel Economy" android:layout_weight="1.0" style="?materialIconButtonOutlinedStyle" />
                <Button android:id="@id/capacityRelearn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Capacity Relearn" android:layout_weight="1.0" style="?materialIconButtonOutlinedStyle" />
            </LinearLayout>
            <LinearLayout android:orientation="horizontal" android:padding="10.0dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                <Button android:id="@id/unlockHv" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HV Battery Unlock\nClear SHVCS, P1FFF, P0AFA, etc" android:layout_weight="1.0" app:icon="@drawable/outline_bolt_24" style="?materialIconButtonOutlinedStyle" />
            </LinearLayout>
            <TextView android:textSize="12.0dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Note: this feature is in beta testing and may not work properly" android:textAlignment="center" />
            <com.google.android.material.divider.MaterialDivider android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginVertical="10.0dp" />
            <LinearLayout android:orientation="horizontal" android:padding="10.0dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                <Button android:id="@id/sync" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sync time" android:layout_weight="1.0" app:icon="@drawable/clock" style="?materialIconButtonOutlinedStyle" />
                <Button android:id="@id/restartCluster" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Restart Cluster" android:layout_weight="1.0" app:icon="@drawable/sync_24px" style="?materialIconButtonOutlinedStyle" />
            </LinearLayout>
            <LinearLayout android:orientation="horizontal" android:padding="10.0dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                <Button android:id="@id/restartHmi" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Restart HMI" android:layout_weight="1.0" app:icon="@drawable/sync_24px" style="?materialIconButtonOutlinedStyle" />
                <Button android:id="@id/restartRadio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Restart Radio" android:layout_weight="1.0" app:icon="@drawable/sync_24px" style="?materialIconButtonOutlinedStyle" />
            </LinearLayout>
            <com.google.android.material.divider.MaterialDivider android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginVertical="10.0dp" />
            <LinearLayout android:orientation="horizontal" android:padding="10.0dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                <Button android:id="@id/rearCamOn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rear Camera ON" android:layout_weight="1.0" style="?materialIconButtonOutlinedStyle" />
                <Button android:id="@id/rearCamOff" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rear Camera OFF" android:layout_weight="1.0" style="?materialIconButtonOutlinedStyle" />
            </LinearLayout>
            <TextView android:textSize="12.0dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Note: this feature may not work on Ampera / Volt Gen 1" android:textAlignment="center" />
            <com.google.android.material.divider.MaterialDivider android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginVertical="10.0dp" />
            <LinearLayout android:orientation="horizontal" android:padding="10.0dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                <Button android:id="@id/tsmTest" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Traffic sign memory test" android:layout_weight="1.0" style="?materialIconButtonOutlinedStyle" />
            </LinearLayout>
            <com.google.android.material.divider.MaterialDivider android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginVertical="10.0dp" />
            <LinearLayout android:orientation="vertical" android:padding="10.0dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                <Button android:layout_gravity="center" android:id="@id/customProcedure" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Run Procedure" style="?materialIconButtonOutlinedStyle" />
                <com.google.android.material.textfield.TextInputLayout android:id="@id/filledTextField" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="10.0dp" android:hint="Insert procedure here" style="?textInputFilledStyle">
                    <com.google.android.material.textfield.TextInputEditText android:id="@id/procedureInput" android:layout_width="match_parent" android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
